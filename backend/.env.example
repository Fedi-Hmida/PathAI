APP_NAME=PathAI
APP_ENV=local
APP_DEBUG=false
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
OPENAI_BASE_URL=
OPENAI_API_KEY=
UNIVERSITY_LLM_API_URL=
UNIVERSITY_LLM_API_KEY=
UNIVERSITY_LLM_MODEL=
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=1
LLM_RETRY_BACKOFF_SECONDS=1
LLM_MOCK_MODE=true
ENABLE_LIVE_LLM_TESTS=false
PATHAI_ENABLE_LLM_ASSESSMENT_AGENT=false
PATHAI_ENABLE_LLM_KNOWLEDGE_MAP_AGENT=false
PATHAI_ENABLE_LLM_CRITIC_AGENT=false
PATHAI_ENABLE_LLM_CURRICULUM_AGENT=false
# LLM fallback policy for enabled LLM agents:
#   fail_loud (default) - on an LLM failure the API returns 503
#     generation_unavailable; the UI shows an explicit "retry" state and never
#     serves another topic's canned deterministic content.
#   deterministic       - opt-in only (offline tests / an intentional offline
#     demo): failures silently degrade to deterministic output.
PATHAI_LLM_FALLBACK_MODE=fail_loud
MONGODB_URI=
MONGODB_DATABASE_NAME=pathai
REPOSITORY_BACKEND=fake
# Authentication (JWT). Disabled by default; the local demo runs with no auth.
# Set PATHAI_ENABLE_AUTH=true only together with a real JWT_SECRET_KEY.
PATHAI_ENABLE_AUTH=false
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600
REFRESH_COOKIE_NAME=pathai_refresh
# Keep true in production (HTTPS). Set false only for local http dev so the
# browser will store/send the refresh cookie over http://localhost.
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_SAMESITE=lax
