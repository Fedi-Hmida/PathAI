APP_NAME=PathAI API
APP_VERSION=0.1.0
APP_ENV=local
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
ENABLE_DOCS=true
ENABLE_DEV_ENDPOINTS=true
ENABLE_DEMO_ENDPOINTS=true
DEMO_MODE=true
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=120
AUDIT_LOG_ENABLED=false
REDACT_LOG_VALUES=true
EXPOSE_INTERNAL_ERRORS=true
TRACE_PRIVACY_MODE=strict

# Use a local URI for local MongoDB or a MongoDB Atlas SRV URI in real .env.
# Never commit real credentials.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=pathai_dev
MONGODB_SERVER_SELECTION_TIMEOUT_MS=1000
MONGODB_CONNECT_ON_STARTUP=true

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=7

UNIVERSITY_LLM_API_URL=
UNIVERSITY_LLM_API_KEY=
OPENAI_BASE_URL=
OPENAI_API_KEY=
UNIVERSITY_LLM_MODEL=pathai-university-default
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=0.5
LLM_MOCK_MODE=true
LLM_PROMPT_VERSION=v1

TAVILY_API_KEY=
CHROMA_PERSIST_DIR=./chroma_db

LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pathai-dev
SENTRY_DSN=
SENDGRID_API_KEY=
